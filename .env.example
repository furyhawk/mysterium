# ── Mysterium Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in the values.

# verity-rag server URL (default: http://localhost:8100)
RAG_SERVER_URL=http://localhost:8100

# Anthropic API key for research agent
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional: custom base URL for an Anthropic-compatible gateway/proxy
# ANTHROPIC_BASE_URL=https://your-gateway.example.com

# Mysterium server configuration
HOST=0.0.0.0
PORT=8200
LOG_LEVEL=info
